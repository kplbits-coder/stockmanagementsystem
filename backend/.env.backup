# ─── Common ───────────────────────────────────────────────────────────────────
JWT_SECRET="rms-super-secret-jwt-key"
JWT_EXPIRES_IN="7d"
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# ─── Default database (used by Prisma CLI for migrations/seed) ────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stock_management_db?schema=public"

# ─── Tenant Databases ─────────────────────────────────────────────────────────
# Each client gets its own database. Create these in PostgreSQL:
#   CREATE DATABASE scoopmandu_db;
#   CREATE DATABASE rkt_tradings_db;

DATABASE_URL_SCOOPMANDU="postgresql://postgres:postgres@localhost:5432/scoopmandu_db?schema=public"
DATABASE_URL_RKT="postgresql://postgres:postgres@localhost:5432/rkt_tradings_db?schema=public"
